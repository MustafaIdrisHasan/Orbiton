PORT=5000
NODE_ENV=development
JWT_SECRET=change-me
# Docker Postgres (recommended): from repo root run
#   npm run docker:postgres-up
#   npm run db:bootstrap --workspace @orbiton/api
# Then use:
POSTGRES_URL=postgres://orbiton:orbiton@127.0.0.1:5432/orbiton
#
# Local dev (native PostgreSQL): create role/db + schema via:
#   $env:POSTGRES_SUPERUSER_PASSWORD = '<postgres-superuser-password>'
#   npm run db:setup-local --workspace @orbiton/api
#POSTGRES_URL=postgres://orbiton_user:password@127.0.0.1:5432/orbiton
MONGO_URL=mongodb://localhost:27017/orbiton
# Dev: leave unset to allow http://localhost:5173+5174 and 127.0.0.1 (two Vite instances = two logins at once). Production: set your site URL(s), comma-separated.
# CORS_ORIGIN=http://localhost:5173
# CORS_ORIGIN=https://app.example.com
CORS_ORIGIN=
STORAGE_BUCKET=orbiton-dev
#
# ML resume store in Postgres (optional; default is in-memory)
#USE_POSTGRES=true
#
# ML API feature flags (optional)
#ENABLE_RESUME_SCORING=true
#ENABLE_MATCHING=true
#ENABLE_PREDICTION=true
#ML_SERVICE_URL=http://localhost:8000
#
# apps/intelligence FastAPI stack (optional; local defaults in intelligence/client.js)
#RESUME_SERVICE_URL=http://127.0.0.1:8001
#MATCHING_SERVICE_URL=http://127.0.0.1:8002
#PREDICTION_SERVICE_URL=http://127.0.0.1:8003
#
# Redis for BullMQ embedding queues (optional)
#REDIS_URL=redis://127.0.0.1:6379/0
#
# HMAC for Python → Node webhooks (/api/v1/internal/*)
#INTERNAL_HMAC_SECRET=change-me-internal-webhook
#
# Use pgvector + matching_service for GET /matching/* (requires migrations + embeddings)
#USE_PGVECTOR_MATCHING=false

